@model List<GameStore.Models.Game>

@{
    ViewData["Title"] = "Главная";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Главная</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    @await Html.PartialAsync("_TopBar")

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-box error-alert">@TempData["ErrorMessage"]</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-box success-alert">@TempData["SuccessMessage"]</div>
    }

    <div class="page-wrap">
        <div class="hero">
            <h1>Магазин игр</h1>
            <p>Цифровые игры, торговая площадка и инвентарь предметов</p>
        </div>

        <a class="catalog-link center-link" href="/Games">Перейти к полному каталогу игр</a>

        <h2 class="section-title">Рекомендуемые игры</h2>

        @if (Model.Count == 0)
        {
            <p class="empty-text center-text">Игры не найдены.</p>
        }
        else
        {
            <div class="games-grid">
                @foreach (var game in Model)
                {
                    <div class="game-card">
                        <h3>@game.Title</h3>
                        <div class="price">@game.Price ₽</div>

                        <div class="card-actions">
                            <a class="ghost-btn" href="/Games/Details/@game.Id">Открыть</a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</body>
</html>