@model List<GameStore.Models.Game>

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Каталог игр</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    @await Html.PartialAsync("_TopBar")

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-box error-alert">@TempData["ErrorMessage"]</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-box success-alert">@TempData["SuccessMessage"]</div>
    }

    <div class="page">
        <h1>Каталог игр</h1>

        <div class="games-list">
            @foreach (var game in Model)
            {
                <div class="game-row">
                    <h3>@game.Title</h3>
                    <div class="price">@game.Price ₽</div>

                    <div class="mb-20">
                        <span>Разработчик: @game.Developer</span><br />
                        <span>Издатель: @game.Publisher</span>
                    </div>

                    <div class="row-actions">
                        <a class="btn" href="/Games/Details/@game.Id">Подробнее</a>

                        <form method="post" action="/Games/Buy/@game.Id" style="margin:0;">
                            <button class="btn" type="submit">Купить</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

</body>
</html>