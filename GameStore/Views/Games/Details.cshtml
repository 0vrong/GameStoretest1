@model GameStore.Models.Game

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>@Model.Title</title>
    <style>
            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                background: #121820;
                color: #d6e0ea;
            }

            .page {
                max-width: 900px;
                margin: 0 auto;
                padding: 32px 24px;
            }

            .card {
                background: linear-gradient(180deg, #16202d 0%, #10161d 100%);
                border: 1px solid #24384a;
                border-radius: 10px;
                padding: 26px;
            }

            h1 {
                margin-top: 0;
                color: #ffffff;
                font-size: 34px;
            }

            a {
                color: #66c0f4;
                text-decoration: none;
            }

                a:hover {
                    color: #ffffff;
                }

            .price {
                color: #a4d007;
                font-size: 22px;
                font-weight: 700;
                margin: 18px 0;
            }

            .btn {
                border: 1px solid #3b6e8c;
                background: linear-gradient(180deg, #2a475e 0%, #1b3649 100%);
                color: #eaf7ff;
                padding: 10px 18px;
                border-radius: 4px;
                cursor: pointer;
                font-size: 14px;
            }
    </style>
</head>
<body>
    <div class="page">
        <a href="/Games">Назад к каталогу</a>

        <div class="card" style="margin-top:18px;">
            <h1>@Model.Title</h1>

            <p><b>Разработчик:</b> @Model.Developer</p>
            <p><b>Издатель:</b> @Model.Publisher</p>

            <div class="price">@Model.Price ₽</div>

            <form method="post" action="/Games/Buy/@Model.Id">
                <button class="btn" type="submit">Купить</button>
            </form>
        </div>
    </div>
</body>
</html>