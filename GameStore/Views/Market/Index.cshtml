@model List<GameStore.Models.MarketListing>

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Торговая площадка</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    @await Html.PartialAsync("_TopBar")

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-box error-alert">@TempData["ErrorMessage"]</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-box success-alert">@TempData["SuccessMessage"]</div>
    }

    <div class="page">
        <h1>Торговая площадка</h1>

        @if (Model.Count == 0)
        {
            <p class="empty">Лотов пока нет</p>
        }
        else
        {
            <div class="market-list">
                @foreach (var item in Model)
                {
                    <div class="lot-card">
                        <h3>@item.Item.Name</h3>
                        <p>Игра: @item.Item.Game.Title</p>
                        <p>Продавец: @item.Seller.UserName</p>
                        <div class="price">@item.Price ₽</div>

                        <form method="post" action="/Market/Buy/@item.Id">
                            <button class="btn" type="submit">Купить</button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>

</body>
</html>