@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />

    <title>GameStore</title>

    <style>

        body {
            font-family: Arial;
        }

        #notificationsBox {
            display: none;
            position: absolute;
            right: 20px;
            top: 60px;
            width: 300px;
            background: white;
            border: 1px solid gray;
            padding: 10px;
        }

        .notification {
            border-bottom: 1px solid #ddd;
            padding: 5px;
        }

    </style>

</head>

<body>

    <header>

        @{
            var userId = HttpContextAccessor.HttpContext.Session.GetInt32("UserId");
            var username = HttpContextAccessor.HttpContext.Session.GetString("Username");
        }

        @if (userId != null)
        {
            <div>

                <b>@username</b>

                |

                <a href="/">Главная</a>

                <a href="/Game">Игры</a>

                <a href="/User/Library">Библиотека</a>

                <a href="/User/Inventory">Инвентарь</a>

                <a href="/Market">Маркет</a>

                |

                <button onclick="toggleNotifications()">🔔 Уведомления</button>

                |

                <a href="/Account/Logout">Выйти</a>

            </div>
        }
        else
        {
            <div>

                <a href="/">Главная</a>

                <a href="/Account/Login">Вход</a>

                <a href="/Account/Register">Регистрация</a>

            </div>
        }

    </header>

    <div id="notificationsBox"></div>

    <hr />

    <div>

        @RenderBody()

    </div>

    <script>

        function toggleNotifications(){

            const box = document.getElementById("notificationsBox");

            if(box.style.display === "none" || box.style.display === ""){

                fetch("/Notification/Unread")
                .then(r => r.json())
                .then(data => {

                    box.innerHTML = "";

                    if(data.length === 0){
                        box.innerHTML = "Нет уведомлений";
                    }

                    data.forEach(n => {

                        const div = document.createElement("div");

                        div.className = "notification";

                        div.innerText = n.message;

                        box.appendChild(div);

                    });

                });

                box.style.display = "block";

                fetch("/Notification/MarkRead",{
                    method:"POST"
                });

            }
            else{

                box.style.display = "none";

            }

        }

    </script>

</body>
</html>