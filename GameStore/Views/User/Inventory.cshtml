@model List<GameStore.Models.UserItem>

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Инвентарь</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    @await Html.PartialAsync("_TopBar")

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-box error-alert">@TempData["ErrorMessage"]</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-box success-alert">@TempData["SuccessMessage"]</div>
    }

    <div class="page-wide">
        <h1>Инвентарь</h1>

        @if (Model.Count == 0)
        {
            <p class="empty">Инвентарь пуст</p>
        }
        else
        {
            <div class="inventory-grid">
                @foreach (var item in Model)
                {
                    <div class="item-card">
                        <div>
                            <h3>@item.Item.Name</h3>
                            <div class="item-meta">Игра: @item.Item.Game.Title</div>
                        </div>

                        <form class="sell-form" method="post" action="/Market/SellItem">
                            <input type="hidden" name="itemId" value="@item.ItemId" />
                            <input type="number" name="price" placeholder="Цена продажи" required />
                            <button class="btn" type="submit">Продать</button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>

</body>
</html>