@model List<GameStore.Models.UserItem>

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Инвентарь</title>
    <style>
            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                background: #121820;
                color: #d6e0ea;
            }

            .page {
                max-width: 1400px;
                margin: 0 auto;
                padding: 32px 24px;
            }

            h1 {
                color: #ffffff;
            }

            a {
                color: #66c0f4;
                text-decoration: none;
            }

                a:hover {
                    color: #ffffff;
                }

            .grid {
                display: grid;
                grid-template-columns: repeat(6, 1fr);
                gap: 16px;
                margin-top: 24px;
            }

            .item-card {
                background: linear-gradient(180deg, #16202d 0%, #10161d 100%);
                border: 1px solid #24384a;
                border-radius: 8px;
                padding: 14px;
                min-height: 220px;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
            }

                .item-card h3 {
                    margin: 0 0 10px;
                    color: #ffffff;
                    font-size: 18px;
                }

            .item-meta {
                color: #8f98a0;
                font-size: 14px;
                margin-bottom: 14px;
            }

            .sell-form input {
                width: 100%;
                margin-bottom: 10px;
                padding: 8px 10px;
                border-radius: 4px;
                border: 1px solid #3a5268;
                background: #0f141a;
                color: #ffffff;
            }

            .btn {
                width: 100%;
                border: 1px solid #3b6e8c;
                background: linear-gradient(180deg, #2a475e 0%, #1b3649 100%);
                color: #eaf7ff;
                padding: 9px 12px;
                border-radius: 4px;
                cursor: pointer;
            }

            .empty {
                color: #8f98a0;
                margin-top: 20px;
            }
    </style>
</head>
<body>
    <div class="page">
        <h1>Инвентарь</h1>
        <a href="/">На главную</a>

        @if (Model.Count == 0)
        {
            <p class="empty">Инвентарь пуст</p>
        }
        else
        {
            <div class="grid">
                @foreach (var item in Model)
                {
                    <div class="item-card">
                        <div>
                            <h3>@item.Item.Name</h3>
                            <div class="item-meta">Игра: @item.Item.Game.Title</div>
                        </div>

                        <form class="sell-form" method="post" action="/Market/SellItem">
                            <input type="hidden" name="itemId" value="@item.ItemId" />
                            <input type="number" name="price" placeholder="Цена продажи" required />
                            <button class="btn" type="submit">Продать</button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>
</body>
</html>