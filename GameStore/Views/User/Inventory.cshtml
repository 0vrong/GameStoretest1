@model List<GameStore.Models.UserItem>

<h1>Инвентарь</h1>

<a href="/">На главную</a>

<hr />

@if (Model.Count == 0)
{
    <p>Инвентарь пуст</p>
}
else
{
    foreach (var item in Model)
    {
        <div style="border:1px solid gray; padding:10px; margin-bottom:10px">

            <h3>@item.Item.Name</h3>

            <p>Игра: @item.Item.Game.Title</p>

            <form method="post" action="/Market/SellItem">
                <input type="hidden" name="itemId" value="@item.ItemId" />

                <input type="number" name="price" placeholder="Цена" required />

                <button type="submit">Продать</button>
            </form>

        </div>
    }
}