@model List<GameStore.Models.Game>

@{
    ViewData["Title"] = "Библиотека";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Библиотека</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    @await Html.PartialAsync("_TopBar")

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-box error-alert">@TempData["ErrorMessage"]</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-box success-alert">@TempData["SuccessMessage"]</div>
    }

    <div class="page">
        <h1>Моя библиотека игр</h1>

        @if (Model.Count == 0)
        {
            <p class="empty">У вас пока нет игр.</p>
        }
        else
        {
            <div class="library-grid">
                @foreach (var game in Model)
                {
                    <div class="library-card">
                        <h3>@game.Title</h3>
                        <div class="price">@game.Price ₽</div>
                    </div>
                }
            </div>
        }
    </div>

</body>
</html>