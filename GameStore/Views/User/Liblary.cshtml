@model List<GameStore.Models.Game>

@{
    ViewData["Title"] = "Библиотека";
}

<h1>Моя библиотека игр</h1>

<a href="/">На главную</a>

<hr />

@if (Model.Count == 0)
{
    <p>У вас пока нет игр.</p>
}
else
{
    @foreach (var game in Model)
    {
        <div style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">
            <h3>@game.Title</h3>
            <p>Цена: @game.Price ₽</p>
        </div>
    }
}